# Supabase — Electron renderer (VITE_ prefix required for electron-vite)
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase — backend/dispatcher (Railway)
# Uses service role key to bypass RLS
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — daemon (local launchd service)
# Anon key is sufficient; daemon operates under device_id scope
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
QUEUE_DEVICE_ID=   # copy from DevTools → Application → Local Storage → queue:device_id

# API keys (stored encrypted in Supabase settings table, not here)
# Set these in the app's Settings panel once it's running.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=    (optional — only needed for Whisper voice fallback)
